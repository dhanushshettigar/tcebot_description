<?xml version="1.0"?>
<robot name="tcebot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find tcebot_description)/urdf/materials.xacro" />

  <link name="base_link">
    <inertial>
      <origin xyz="-0.008564396962539625 -0.014118727809814683 0.06971558782741398" rpy="0 0 0" />
      <mass value="2.6923940926278465" />
      <inertia ixx="0.009628" iyy="0.007653" izz="0.007608" ixy="-9e-06" iyz="0.000253"
        ixz="-1.3e-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/base_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="light_blue" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/base_link.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <inertial>
      <origin xyz="-0.015689995537150135 1.9354447389208218e-07 -1.8592013856927325e-07" rpy="0 0 0" />
      <mass value="0.23341302374486034" />
      <inertia ixx="0.00016" iyy="9.6e-05" izz="9.6e-05" ixy="0.0" iyz="-0.0" ixz="0.0" />
    </inertial>
    <visual>
      <origin xyz="0.045157 0.069525 -0.021641" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/left_wheel.stl"
          scale="0.001 0.001 0.001" />
      </geometry>
      <material name="dark_grey" />
    </visual>
    <collision>
      <origin xyz="0.045157 0.069525 -0.021641" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/left_wheel.stl"
          scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <link name="right_wheel">
    <inertial>
      <origin xyz="0.014689947615311807 1.9270939681514943e-07 -6.875961525952545e-07" rpy="0 0 0" />
      <mass value="0.23341306478013937" />
      <inertia ixx="0.00016" iyy="9.6e-05" izz="9.6e-05" ixy="-0.0" iyz="0.0" ixz="0.0" />
    </inertial>
    <visual>
      <origin xyz="-0.030621 0.069525 -0.021641" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/right_wheel.stl"
          scale="0.001 0.001 0.001" />
      </geometry>
      <material name="dark_grey" />
    </visual>
    <collision>
      <origin xyz="-0.030621 0.069525 -0.021641" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/right_wheel.stl"
          scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <link name="caster">
    <inertial>
      <origin xyz="8.760371028013886e-06 -0.015006453046049681 -0.008779771570198129" rpy="0 0 0"/>
      <mass value="0.02176904247885505"/>
      <inertia ixx="1e-06" iyy="1e-06" izz="1e-06" ixy="-0.0" iyz="0.0" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.008206 -0.049407 -0.007659" rpy="0 0 0"/>
      <geometry>
       <mesh filename="package://tcebot_description/meshes/caster.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.008206 -0.049407 -0.007659" rpy="0 0 0"/>
      <geometry>
       <mesh filename="package://tcebot_description/meshes/caster.stl" scale="0.001 0.001 0.001"/>
      </geometry>
  </collision>
  </link>

  <link name="lidar">
    <inertial>
      <origin xyz="0.01253399240967995 0.034954225501993154 0.031144245322156733" rpy="0 0 0" />
      <mass value="0.5204475795482929" />
      <inertia ixx="0.00026" iyy="0.000181" izz="0.000381" ixy="3e-06" iyz="-2.3e-05" ixz="2e-06" />
    </inertial>
    <visual>
      <origin xyz="0.024795 0.052459 -0.139659" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/lidar.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="dark_grey" />
    </visual>
    <collision>
      <origin xyz="0.024795 0.052459 -0.139659" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/lidar.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <link name="camera">
    <inertial>
      <origin xyz="-8.673617379884035e-18 -0.0015001643555897087 -3.9943743584958114e-07"
        rpy="0 0 0" />
      <mass value="0.007596909964138296" />
      <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="-0.0" iyz="0.0" ixz="0.0" />
    </inertial>
    <visual>
      <origin xyz="0.008 0.091056 -0.138159" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/camera.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="yellow" />
    </visual>
    <collision>
      <origin xyz="0.008 0.091056 -0.138159" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://tcebot_description/meshes/camera.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <joint name="left_motor" type="continuous">
    <origin xyz="-0.045157 -0.069525 0.021641" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="left_wheel" />
    <axis xyz="0.1 0.0 0.0" />
  </joint>

  <joint name="right_motor" type="continuous">
    <origin xyz="0.030621 -0.069525 0.021641" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="right_wheel" />
    <axis xyz="0.1 0.0 0.0" />
  </joint>

  <joint name="rigid1" type="fixed">
    <origin xyz="-0.024795 -0.052459 0.139659" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar" />
  </joint>

  <joint name="rigid2" type="fixed">
    <origin xyz="-0.008 -0.091056 0.138159" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera" />
  </joint>

  <joint name="rigid3" type="fixed">
    <origin xyz="-0.008206 0.049407 0.007659" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="caster"/>
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

</robot>